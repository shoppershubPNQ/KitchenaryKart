# Pooled Neon connection string — same value as admin/.env
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"

# Admin app base (used to POST inquiries and fetch images that live on admin's domain in prod)
ADMIN_API_BASE="http://localhost:3000"
NEXT_PUBLIC_ADMIN_API_BASE="http://localhost:3000"

# WhatsApp number used by the floating button + contact page
NEXT_PUBLIC_WHATSAPP_NUMBER="919890352455"

# Upstash Redis (REST) — persistent OTP store across serverless invocations.
# Get from console.upstash.com → your DB → Connect → REST tab.
UPSTASH_REDIS_REST_URL="https://your-db-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-rest-token-here"

# Set to "true" to accept "123456" as a universal OTP (testing / no SMS gateway).
# MUST be "false" or unset in production once a real SMS gateway is wired up.
OTP_DEV_BYPASS="true"
